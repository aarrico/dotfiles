unbind C-b
set -g prefix C-a
bind C-a send-prefix
set -s escape-time 0
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g mouse on

unbind '"'
unbind %
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

set -g default-terminal "xterm-256color"
set -as terminal-features ",xterm-256color:RGB"

set -g status-style "bg=default,fg={{ .colors.fg }}"
set -g pane-border-style "fg={{ .colors.border }}"
set -g pane-active-border-style "fg={{ .colors.blue }}"
set -g status-left "#[fg={{ .colors.blue }},bold] 󰘓 #S #[fg={{ .colors.border }}]▪ "
set -g status-left-length 50
set -g status-right "#[fg={{ .colors.purple }}]󱎫 %H:%M #[fg={{ .colors.border }}]▪ #[fg={{ .colors.yellow }}] %Y-%m-%d "
set -g status-justify left
set -g window-status-style "fg={{ .colors.inactive }}"
set -g window-status-format " #I:#W "
set -g window-status-current-style "fg={{ .colors.cyan }},bold"
set -g window-status-current-format " #I:#W* "
